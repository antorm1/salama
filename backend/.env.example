# Salama backend configuration (copy to .env)
# All values have safe defaults if omitted.

# SECURITY — generate a strong random key in production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-insecure-change-me-please-use-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# DATABASE
# Local dev (default, zero-config):  sqlite:///./salama.db
# Production (PostgreSQL):           postgresql+psycopg://USER:PASSWORD@HOST:5432/salama
DATABASE_URL=sqlite:///./salama.db

# APP
APP_NAME=Salama Community Safety
# Comma-separated list of allowed CORS origins (frontend dev/prod URLs)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SEED ADMIN (created automatically on first startup if no users exist)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me
SEED_ADMIN_PHONE=+254700000000
